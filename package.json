{
  "name": "ts-aitool-v2",
  "displayName": "TS_AiTool V2",
  "description": "AI-powered project management with multi-agent system, Hebrew RTL support, and smart coding assistant",
  "version": "0.1.0",
  "publisher": "ts-aitool-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ts-aitool-dev/ts-aitool.git"
  },
  "bugs": {
    "url": "https://github.com/ts-aitool-dev/ts-aitool/issues"
  },
  "homepage": "https://github.com/ts-aitool-dev/ts-aitool#readme",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "hebrew",
    "rtl",
    "assistant",
    "coding",
    "agents",
    "project-management"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tsAiTool",
          "title": "TS AiTool",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "tsAiTool": [
        {
          "type": "webview",
          "id": "tsAiTool.mainView",
          "name": "TS AiTool"
        }
      ]
    },
    "commands": [
      {
        "command": "tsAiTool.togglePanel",
        "title": "TS AiTool: פתח/סגור פאנל AI"
      },
      {
        "command": "tsAiTool.newChat",
        "title": "TS AiTool: פתח שיחה חדשה",
        "icon": "$(add)"
      },
      {
        "command": "tsAiTool.cancel",
        "title": "TS AiTool: בטל בקשה",
        "icon": "$(debug-stop)"
      },
      {
        "command": "tsAiTool.clearChat",
        "title": "TS AiTool: נקה שיחה"
      },
      {
        "command": "tsAiTool.fullScreen",
        "title": "TS AiTool: מסך מלא",
        "icon": "$(screen-full)"
      },
      {
        "command": "tsAiTool.newProject",
        "title": "TS AiTool: פרויקט חדש",
        "icon": "$(folder-opened)"
      },
      {
        "command": "tsAiTool.switchAgent",
        "title": "TS AiTool: בחר סוכן"
      },
      {
        "command": "tsAiTool.splitView",
        "title": "TS AiTool: תצוגה מפוצלת"
      },
      {
        "command": "tsAiTool.searchChats",
        "title": "TS AiTool: חפש בשיחות",
        "icon": "$(search)"
      },
      {
        "command": "tsAiTool.exportChat",
        "title": "TS AiTool: ייצא שיחה נוכחית",
        "icon": "$(export)"
      },
      {
        "command": "tsAiTool.switchModel",
        "title": "TS AiTool: החלף מודל Claude",
        "icon": "$(symbol-enum)"
      },
      {
        "command": "tsAiTool.runDoctor",
        "title": "TS AiTool: הרץ אבחון מערכת",
        "icon": "$(pulse)"
      },
      {
        "command": "tsAiTool.selectAgent",
        "title": "TS AiTool: בחר סוכן",
        "icon": "$(person)"
      },
      {
        "command": "tsAiTool.toggleFullscreen",
        "title": "TS AiTool: מעבר למסך מלא",
        "icon": "$(screen-full)"
      },
      {
        "command": "tsAiTool.askAboutCode",
        "title": "שאל את Claude על הקוד הנבחר",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "tsAiTool.securityCheckCode",
        "title": "בדוק אבטחה בקוד",
        "icon": "$(shield)"
      },
      {
        "command": "tsAiTool.explainCode",
        "title": "הסבר קוד",
        "icon": "$(lightbulb)"
      },
      {
        "command": "tsAiTool.improveCode",
        "title": "שפר קוד",
        "icon": "$(sparkle)"
      },
      {
        "command": "tsAiTool.analyzeFile",
        "title": "נתח קובץ עם Claude",
        "icon": "$(file-code)"
      },
      {
        "command": "tsAiTool.securityScanFile",
        "title": "בדוק אבטחה",
        "icon": "$(shield)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "tsAiTool.askAboutCode",
          "when": "editorHasSelection",
          "group": "tsAiTool@1"
        },
        {
          "command": "tsAiTool.explainCode",
          "when": "editorHasSelection",
          "group": "tsAiTool@2"
        },
        {
          "command": "tsAiTool.improveCode",
          "when": "editorHasSelection",
          "group": "tsAiTool@3"
        },
        {
          "command": "tsAiTool.securityCheckCode",
          "when": "editorHasSelection",
          "group": "tsAiTool@4"
        }
      ],
      "explorer/context": [
        {
          "command": "tsAiTool.analyzeFile",
          "when": "!explorerResourceIsFolder",
          "group": "tsAiTool@1"
        },
        {
          "command": "tsAiTool.securityScanFile",
          "when": "!explorerResourceIsFolder",
          "group": "tsAiTool@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tsAiTool.togglePanel",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "tsAiTool.fullScreen",
        "key": "ctrl+shift+f1",
        "mac": "cmd+shift+f1"
      },
      {
        "command": "tsAiTool.newChat",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      },
      {
        "command": "tsAiTool.searchChats",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "focusedView == 'tsAiTool.mainView'"
      },
      {
        "command": "tsAiTool.clearChat",
        "key": "ctrl+l",
        "when": "focusedView == 'tsAiTool.mainView'"
      },
      {
        "command": "tsAiTool.switchAgent",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "focusedView == 'tsAiTool.mainView'"
      },
      {
        "command": "tsAiTool.splitView",
        "key": "ctrl+shift+2",
        "mac": "cmd+shift+2",
        "when": "focusedView == 'tsAiTool.mainView'"
      },
      {
        "command": "tsAiTool.toggleFullscreen",
        "key": "ctrl+shift+f2",
        "mac": "cmd+shift+f2"
      }
    ],
    "configuration": {
      "title": "TS AiTool",
      "properties": {
        "tsAiTool.connectionMode": {
          "type": "string",
          "default": "cli",
          "enum": [
            "cli",
            "api"
          ],
          "enumItemLabels": [
            "Claude CLI — Your Subscription (Recommended)",
            "API Key — Pay per token"
          ],
          "description": "Connection mode: CLI uses your Claude Max/Pro subscription, API uses pay-per-token",
          "order": 0
        },
        "tsAiTool.apiKey": {
          "type": "string",
          "default": "",
          "markdownDeprecationMessage": "API keys are now stored securely. Use the extension settings panel to enter your API key.",
          "description": "[Deprecated] API key is now stored securely via SecretStorage. Use the extension UI to set it.",
          "order": 1
        },
        "tsAiTool.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "enum": [
            "claude-sonnet-4-20250514",
            "claude-opus-4-20250514",
            "claude-haiku-4-5-20251001"
          ],
          "enumItemLabels": [
            "Claude Sonnet 4 (Recommended)",
            "Claude Opus 4 (Most Capable)",
            "Claude Haiku 4.5 (Fastest)"
          ],
          "description": "Default AI model",
          "order": 1
        },
        "tsAiTool.language": {
          "type": "string",
          "default": "he",
          "enum": [
            "he",
            "en"
          ],
          "enumItemLabels": [
            "עברית",
            "English"
          ],
          "description": "Interface language",
          "order": 2
        },
        "tsAiTool.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "dark",
            "light"
          ],
          "description": "Color theme",
          "order": 3
        },
        "tsAiTool.fontSize": {
          "type": "number",
          "default": 14,
          "minimum": 10,
          "maximum": 24,
          "description": "Chat font size",
          "order": 4
        },
        "tsAiTool.maxTokens": {
          "type": "number",
          "default": 4096,
          "minimum": 256,
          "maximum": 200000,
          "description": "Max tokens per response",
          "order": 5
        },
        "tsAiTool.learningMode": {
          "type": "boolean",
          "default": false,
          "description": "Add detailed Hebrew comments to all code",
          "order": 6
        },
        "tsAiTool.permissionPreset": {
          "type": "string",
          "default": "normal",
          "enum": [
            "conservative",
            "normal",
            "full"
          ],
          "enumItemLabels": [
            "Conservative (Ask for everything)",
            "Normal (Auto-read, ask for writes)",
            "Full (Auto-approve all)"
          ],
          "description": "Tool permission level",
          "order": 7
        },
        "tsAiTool.quickActionsVisible": {
          "type": "boolean",
          "default": true,
          "description": "Show quick action buttons",
          "order": 8
        },
        "tsAiTool.autoContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect and attach relevant files",
          "order": 9
        },
        "tsAiTool.voiceLanguage": {
          "type": "string",
          "default": "he-IL",
          "enum": [
            "he-IL",
            "en-US",
            "ar-SA"
          ],
          "description": "Voice input language",
          "order": 10
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "node esbuild.config.mjs",
    "build:webview": "vite build",
    "dev": "concurrently \"npm run dev:extension\" \"npm run dev:webview\"",
    "dev:extension": "node esbuild.config.mjs --watch",
    "dev:webview": "vite build --watch",
    "package": "npm run build && vsce package",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rimraf dist",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "tsc --noEmit --skipLibCheck",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@types/vscode-webview": "^1.57.4",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "dompurify": "^3.1.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "highlight.js": "^11.10.0",
    "i18next": "^23.11.0",
    "lucide-react": "^0.400.0",
    "marked": "^12.0.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^14.1.0",
    "rimraf": "^5.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
